#include <Arduino.h>
#define RX_PIN 8
#define TX_PIN 7
#define SEATALK_BIT_US   208
#define SEATALK_IDLE_BITS 10
#define SEATALK_MAX_RETRIES  5
#define SEATALK_MAX_BYTES    18
#define HALF_BIT_US       104
#define EDGE_TIMEOUT_US   2080
#define MAX_EDGES         64

// Buffer ISR - uniquement des types atomiques
volatile uint32_t edgeTimes[MAX_EDGES];
volatile uint8_t  edgeLevels[MAX_EDGES];
volatile int      edgeHead = 0;   // écrit par ISR
volatile int      edgeTail = 0;   // lu par loop()
volatile uint32_t lastEdgeTime = 0;

unsigned long lastSendTime = 0;


// État du décodeur
static uint16_t shiftReg    = 0;   // 11 bits : start(1) + data(8) + cmd(1) + stop(1)
static int      bitPos      = 0;   // 0 = on attend le start bit
static bool     inFrame     = false;
static uint8_t  charcount   = 0;
static uint8_t  byteIndex   = 0;
static uint8_t  cmdBit      = 0;
static uint8_t  datagram[18];


void IRAM_ATTR gpioChangeISR() {
    uint32_t now = micros();
    int level = digitalRead(RX_PIN);
    uint32_t duration = now - lastEdgeTime;
    lastEdgeTime = now;

    int next = (edgeHead + 1) % MAX_EDGES;
    if (next != edgeTail) {           // buffer pas plein
        edgeTimes[edgeHead]  = duration;
        edgeLevels[edgeHead] = level;  
        edgeHead = next;
    }
}

// Attendre que le bus soit idle (HIGH) pendant au moins 'minIdleUs' microsecondes
// Retourne true si le bus est libre, false si timeout
bool waitBusIdle(uint32_t minIdleUs = SEATALK_BIT_US * SEATALK_IDLE_BITS, uint32_t timeoutUs = 500000) {
    uint32_t start = micros();
    uint32_t idleStart = 0;
    bool wasHigh = (digitalRead(RX_PIN) == HIGH);

    if (wasHigh) idleStart = micros();

    while (true) {
        bool isHigh = (digitalRead(RX_PIN) == HIGH);

        if (!isHigh) {
            // Bus actif → reset du compteur d'idle
            idleStart = 0;
            wasHigh = false;
        } else {
            if (!wasHigh) {
                // Front montant → début de la période idle
                idleStart = micros();
                wasHigh = true;
            } else if (idleStart > 0 && (micros() - idleStart) >= minIdleUs) {
                return true; // Bus idle suffisamment longtemps
            }
        }

        if ((micros() - start) >= timeoutUs) return false; // Timeout
    }
}

// Envoyer un bit et vérifier ce qui est lu sur RX
// Retourne false si collision détectée
bool sendBitAndCheck(int bitValue) {
    digitalWrite(TX_PIN, bitValue ? HIGH : LOW);
    delayMicroseconds(SEATALK_BIT_US);

    // Lecture du bus pendant/après l'émission du bit
    int rxLevel = digitalRead(RX_PIN);

    // Collision si on envoie HIGH mais on lit LOW (dominant écrase récessif)
    // En SeaTalk : LOW = dominant (start bit, bit=0), HIGH = récessif (idle, bit=1)
    if (bitValue == HIGH && rxLevel == LOW) {
        return false; // Collision : quelqu'un tire le bus LOW pendant qu'on émet HIGH
    }
    return true;
}

// Envoyer un byte SeaTalk (9 bits : 8 data + 1 command bit)
// cmdBit = 1 pour le premier byte (commande), 0 pour les suivants
// Retourne false si collision détectée
bool sendSeatalkByte(uint8_t byteVal, bool isCommand) {
    // Start bit (LOW = dominant)
    if (!sendBitAndCheck(LOW)) return false;

    // 8 data bits LSB first
    for (int b = 0; b < 8; b++) {
        int bit = (byteVal >> b) & 1;
        if (!sendBitAndCheck(bit)) return false;
    }

    // Command/parity bit (9ème bit)
    if (!sendBitAndCheck(isCommand ? HIGH : LOW)) return false;

    // Stop bit (HIGH = récessif/idle)
    digitalWrite(TX_PIN, HIGH);
    delayMicroseconds(SEATALK_BIT_US);

    // Inter-byte gap (optionnel, aide à la stabilité)
    delayMicroseconds(SEATALK_BIT_US * 2);

    return true;
}

// Méthode principale — datagram = tableau de bytes, length = 3 à 18
bool sendSeatalkDatagram(const uint8_t* datagram, uint8_t length) {
    if (length < 3 || length > SEATALK_MAX_BYTES) {
        Serial.println("ERR: longueur invalide");
        return false;
    }

    Serial.print("\n>>> TX Datagram (");
    Serial.print(length);
    Serial.print(" bytes): ");
    for (int i = 0; i < length; i++) {
        Serial.print("0x");
        Serial.print(datagram[i], HEX);
        if (i < length - 1) Serial.print(" ");
    }
    Serial.println();

    for (int attempt = 0; attempt < SEATALK_MAX_RETRIES; attempt++) {
        if (attempt > 0) {
            // Attente aléatoire avant retry (CSMA/CD backoff)
            uint32_t backoff = random(2, 50) * 1000UL; // 2–50 ms en µs
            Serial.print("  CD backoff attempt ");
            Serial.print(attempt + 1);
            Serial.print(", wait ");
            Serial.print(backoff / 1000);
            Serial.println("ms");
            delayMicroseconds(backoff);
        }

        // Attendre que le bus soit libre
        if (!waitBusIdle()) {
            Serial.println("  WARN: timeout attente idle bus");
            continue;
        }

        bool collision = false;

        // Émettre tous les bytes du datagramme
        for (int i = 0; i < length; i++) {
            bool isCmd = (i == 0); // Premier byte = commande (9ème bit = 1)

            if (!sendSeatalkByte(datagram[i], isCmd)) {
                // Collision détectée mid-trame
                Serial.print("  COLLISION au byte ");
                Serial.println(i);

                // Abandonner immédiatement, remettre le bus en idle
                digitalWrite(TX_PIN, HIGH);
                collision = true;
                break;
            }
        }

        if (!collision) {
            Serial.println("<<< TX OK");
            return true;
        }
    }

    Serial.println("ERR: échec après max retries (collision persistante)");
    return false;
}


void handleDatagram() {
    Serial.printf("Message =");
    for(uint8_t i=0;i<charcount;i++) {
        Serial.printf(" %02X",datagram[i]);
    }
    Serial.println();
}

uint8_t reverse8(uint8_t x) {
    x = (x >> 4) | (x << 4);
    x = ((x & 0xCC) >> 2) | ((x & 0x33) << 2);
    x = ((x & 0xAA) >> 1) | ((x & 0x55) << 1);
    return x;
}

void handleByte(uint16_t value, bool endframe=false) {
    uint8_t B   =  reverse8(~( (value >> 2) & 0xFF ));
    uint8_t Cmd = ((value >> 1)+1)%2;
    datagram[byteIndex] = B;
    //for (int i = 10; i >= 0; --i) {
    //    Serial.printf("%d", (value >> i) & 1);
    //}
    //Serial.printf("\n");
    // Serial.printf("Received [byte:%u][inframe:%d][CB=%d][length=%d] = %02X\n", byteIndex, inFrame, Cmd, charcount, B );   
    if(endframe) {
        handleDatagram();
    }
}


void setup() {
    Serial.begin(115200);
    delay(1000);
    Serial.println("STARTUP");

    pinMode(TX_PIN, OUTPUT);
    digitalWrite(TX_PIN, HIGH);
    pinMode(RX_PIN, INPUT_PULLUP);

    lastEdgeTime = micros();
    attachInterrupt(digitalPinToInterrupt(RX_PIN), gpioChangeISR, CHANGE);
}


// Drain the ISR Buffer
void loop() {
    // We are in the last byte, so we can close the frame if timeout (as we can't read the last edge transition)
    if( inFrame == true /*&& byteIndex+1 == charcount */ && micros() - lastEdgeTime > EDGE_TIMEOUT_US ) {
        // Add missing bits
        shiftReg = shiftReg << (11-bitPos);        
        handleByte(shiftReg,true);
        // Serial.printf(" ==> CLOSE FRAME ! ( %d / %d ) bitpos = %d \n", byteIndex+1,charcount,bitPos);        
        inFrame   = false;
        charcount = 0;
        }

    while (edgeTail != edgeHead) {
        uint32_t dur   = edgeTimes[edgeTail];
        uint8_t level = edgeLevels[edgeTail];
        edgeTail = (edgeTail + 1) % MAX_EDGES;
        uint8_t  nBits = (dur + HALF_BIT_US) / SEATALK_BIT_US;

        // ne pas dépasser la taille du shiftReg si level = 0 car cela voudrait dire qu'on aurait pas de startbit au caractère suivant, ce qui est impossible.
        if( level == 0 && (bitPos + nBits > 11)) nBits = 11 - bitPos; 

        Serial.printf("Edge: level=%2d dur=%6uµs  : %2d bits à %d \n", level, dur, nBits , level);
        
        if (dur > EDGE_TIMEOUT_US && level == 0 && inFrame == false) {
            // Début de trame : initialise pour le premier start bit
            // Serial.printf("\n[FRAME START] dur=%uµs\n", dur);
            inFrame   = true;
            shiftReg  = 0;
            bitPos    = 0; // position du bit dans le caractère
            byteIndex = 0; // a augmenter après chaque groupe de 11 bit
            nBits     = 0;
        }

        if (inFrame) {
            while (nBits > 0) {
                // Add the bit to the character
                shiftReg = (shiftReg << 1) + level;
                bitPos++;
                // Decrease number of available bits to handle
                nBits--;
                if (bitPos == 11) {
                    if (byteIndex == 1) {
                        // Total length of datagram = 3 + n  characters      
                        charcount =  reverse8( ~( shiftReg >> 2 )  & 0xF0 ) + 3 ;
                        }
                    handleByte(shiftReg,false);
                    shiftReg = 0;
                    bitPos   = 0;
                    byteIndex++;
                }
            }
        }
    }


    if (millis() - lastSendTime >= 10000) {
        lastSendTime = millis();
        
        uint8_t randomCOG[] = {0x00, 0x04, 0x08, 0x0C};
        static int levelIndex = 0;
        
        uint8_t sendCOG = randomCOG[levelIndex];
        levelIndex = (levelIndex + 1) % 4;
        
        Serial.printf("\n>>> TX Datagram: 0x53 0x20 0x%02X\n",sendCOG);
        // 53  U0  VW      Course over Ground (COG) in degrees:
        //         The two lower  bits of  U * 90 +
        //            the six lower  bits of VW *  2 +
        //            the two higher bits of  U /  2 =
        //            (U & 0x3) * 90 + (VW & 0x3F) * 2 + (U & 0xC) / 8 
        uint8_t dg1[] = {0x53, 0x20, sendCOG};
        sendSeatalkDatagram(dg1, 3);
        uint8_t A = 100+(levelIndex*2);
        uint8_t B = 0;
        uint8_t dg2[] = {0x27, 0x01, A, B};
        sendSeatalkDatagram(dg2, 4);


        delay(10);
    }


    delay(1);
}